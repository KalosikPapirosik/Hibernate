<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_2.xsd"
             version="3.2">

    <persistence-unit name="cinema-pu" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>com.cinema.entity.old.Visitor</class>
        <class>com.cinema.entity.old.Genre</class>
        <class>com.cinema.entity.old.Film</class>
        <class>com.cinema.entity.old.Hall</class>
        <class>com.cinema.entity.old.SeatId</class>
        <class>com.cinema.entity.old.Seat</class>
        <class>com.cinema.entity.old.Screening</class>
        <class>com.cinema.entity.old.Ticket</class>

        <class>com.cinema.entity.Guest</class>
        <class>com.cinema.entity.Housing</class>
        <class>com.cinema.entity.AdditionalServices</class>
        <class>com.cinema.entity.Camp</class>
        <class>com.cinema.entity.Inventory</class>
        <class>com.cinema.entity.HousingCondition</class>
        <class>com.cinema.entity.TypeOfHousing</class>
        <class>com.cinema.entity.Booking</class>

        <properties>
            <property name="jakarta.persistence.jdbc.url"
                      value="jdbc:postgresql://localhost:5435/cinema"/>
            <property name="jakarta.persistence.jdbc.user"     value="postgres"/>
            <property name="jakarta.persistence.jdbc.password"  value="postgres"/>
            <property name="jakarta.persistence.jdbc.driver"
                      value="org.postgresql.Driver"/>

            <property name="hibernate.connection.provider_class"
                      value="org.hibernate.hikaricp.internal.HikariCPConnectionProvider"/>
            <property name="hibernate.hikari.maximumPoolSize"  value="10"/>
            <property name="hibernate.hikari.minimumIdle"      value="2"/>

            <property name="hibernate.hbm2ddl.auto"           value="create"/>
            <property name="hibernate.dialect"
                      value="org.hibernate.dialect.PostgreSQLDialect"/>

            <property name="hibernate.show_sql"                value="true"/>
            <property name="hibernate.format_sql"              value="true"/>
            <property name="hibernate.highlight_sql"           value="true"/>
            <property name="hibernate.use_sql_comments"        value="true"/>

            <property name="hibernate.jdbc.batch_size"         value="25"/>
            <property name="hibernate.order_inserts"           value="true"/>
            <property name="hibernate.order_updates"           value="true"/>

            <property name="hibernate.connection.charSet"      value="UTF-8"/>
        </properties>
    </persistence-unit>
</persistence>
